---
import { getCollection, render } from "astro:content";
import BlogPostLayout from "@layouts/BlogPostLayout.astro";
import Scrollspy from "@src/components/notes/Scrollspy.astro";

export async function getStaticPaths() {
  const posts = await getCollection("notes");

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<BlogPostLayout>
  <aside class="pt-1">
    <a
      href="/"
      class="inline-flex items-center gap-3 text-sm text-neutral-500 transition-colors hover:text-neutral-200"
    >
      <span class="text-xl leading-none">‹</span>
      Back Home
    </a>
  </aside>

  <article class="min-w-0">
    <header class="mb-12">
      <h1 class="text-xl font-semibold tracking-tight text-neutral-100">
        {post.data.title}
      </h1>

      <time class="mt-3 text-sm text-neutral-500">
        {
          post.data.date.toLocaleDateString("en-US", {
            month: "short",
            day: "2-digit",
            year: "numeric",
          })
        } · {post.data.readTime}
      </time>
    </header>
    <div
      class="prose prose-invert prose-p:mb-8 prose-p:leading-8 prose-p:text-neutral-300 prose-headings:mt-12 prose-headings:mb-6 prose-headings:text-base prose-headings:font-semibold prose-headings:text-neutral-100 prose-headings:scroll-mt-12 prose-strong:text-neutral-100 prose-strong:font-semibold prose-em:text-neutral-200 prose-blockquote:border-l prose-blockquote:border-neutral-800 prose-blockquote:pl-7 prose-blockquote:text-neutral-300 prose-a:text-neutral-100 prose-a:font-semibold prose-a:underline prose-a:underline-offset-4 max-w-none"
    >
      <Content />
    </div>
  </article>

  <Scrollspy headings={headings} />
</BlogPostLayout>
