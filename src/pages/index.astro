---
import BaseLayout from "@layouts/BaseLayout.astro";
import ShowCaseList from "@src/components/home/ShowCaseList.astro";
---

<BaseLayout>
  <header class="mb-2 pb-5 text-justify">
    Hi, I’m Leo, a software engineer focused on backend systems and protocol
    engineering, with experience building applications in Rust and smart
    contracts in Solidity. I enjoy working on reliability, security, and
    challenging technical problems, particularly in systems that require strong
    correctness and careful design. I’m currently exploring opportunities to
    work on ambitious products alongside strong engineering teams.
  </header>
  <ShowCaseList
    contentName="work"
    content="work"
    showDay={false}
    linkText="overview"
  />
  <ShowCaseList
    contentName="projects"
    content="projects"
    showDay={false}
    linkText="overview"
  />
  <ShowCaseList contentName="notes" content="notes" linkText="see all" />
</BaseLayout>
