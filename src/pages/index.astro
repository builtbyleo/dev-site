---
import BaseLayout from "@layouts/BaseLayout.astro";
import ShowCaseList from "@src/components/home/ShowCaseList.astro";
---

<BaseLayout>
  <header class="mb-16 space-y-4">
    I'm a software engineer working in Rust.
  </header>
  <ShowCaseList
    contentName="work"
    content="work"
    showDay={false}
    linkText="overview"
  />
  <ShowCaseList
    contentName="projects"
    content="projects"
    showDay={false}
    linkText="overview"
  />
  <ShowCaseList contentName="notes" content="notes" linkText="see all" />
</BaseLayout>
