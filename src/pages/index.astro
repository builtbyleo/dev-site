---
import BaseLayout from "@layouts/BaseLayout.astro";
import ShowCaseList from "@src/components/home/ShowCaseList.astro";
---

<BaseLayout>
  <header class="mb-2 pb-5 text-justify">
    Hi, I’m Leo, a software engineer with 4 years of experience building
    blockchain infrastructure and smart contract protocols. I’ve primarily
    worked across Rust and Solidity. Right now, I’m looking for new
    opportunities where I can work on challenging engineering problems and
    continue growing as a engineer. Feel free to get in touch.
  </header>
  <ShowCaseList
    contentName="work"
    content="work"
    showDay={false}
    linkText="overview"
  />
  <ShowCaseList
    contentName="projects"
    content="projects"
    showDay={false}
    linkText="overview"
  />
  <ShowCaseList contentName="notes" content="notes" linkText="see all" />
</BaseLayout>
