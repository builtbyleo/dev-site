---
import "@src/global.css";

import { ClientRouter } from "astro:transitions";

const description =
  "Notes by Leonard Paturel on software engineering and technical topics.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>Blog</title>

    <ClientRouter />
  </head>
  <body
    class="mx-auto grid max-w-7xl grid-cols-[180px_minmax(0,680px)_260px] gap-16 bg-[#101010] px-8 py-16"
  >
    <slot />
  </body>
</html>
