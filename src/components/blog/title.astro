---
const { post } = Astro.props;
---

<header class="mb-12">
  <h1 class="text-xl font-semibold tracking-tight text-neutral-100">
    {post.data.title}
  </h1>

  <p class="mt-3 text-sm text-neutral-500">
    {
      new Date(post.data.pubDate).toLocaleDateString("en-US", {
        month: "short",
        day: "2-digit",
        year: "numeric",
      })
    } · {post.data.readTime}
  </p>
</header>
