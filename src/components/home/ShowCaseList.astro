---
import type { CollectionKey } from "astro:content";
import { getCollection } from "astro:content";

interface Props {
  contentName: string;
  linkText?: string;
  content: CollectionKey;
}

const { contentName, content, linkText } = Astro.props;

const contentList = await getCollection(content);
---

<section class="mb-12 pt-10">
  <div class="mb-6 flex items-baseline justify-between">
    <h2 class="flex items-center text-2xl font-semibold text-white">
      {contentName}
    </h2>

    <a
      class="text-accent group inline-flex items-center gap-1 text-sm hover:underline"
      href={contentName}
    >
      {linkText ?? contentName}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-arrow-up-right h-4 w-4 transition-transform duration-200 group-hover:translate-x-1 group-hover:-translate-y-1"
      >
        <path d="M7 7h10v10"></path>
        <path d="M7 17 17 7"></path>
      </svg>
    </a>
  </div>

  <div class="space-y-3">
    {
      contentList.map((item) => (
        <a
          class="group flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-4"
          href={`${contentName}/${item.id}`}
        >
          <span class="shrink-0 text-sm text-gray-500 tabular-nums sm:w-28">
            {new Date(item.data.date).toLocaleDateString("en-US", {
              month: "short",
              day: "2-digit",
              year: "numeric",
            })}
          </span>

          <span class="group-hover:text-accent text-gray-200 transition-colors duration-200">
            {item.data.title}
          </span>
        </a>
      ))
    }
  </div>
</section>
