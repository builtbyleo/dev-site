---
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "home" },
  { href: "/work", label: "work" },
  { href: "/projects", label: "projects" },
  { href: "/blog", label: "blog" },
];

const baseLinkClass =
  "hover:text-white transition-colors duration-200 py-2 px-1.5 sm:px-0 sm:py-0";
---

<nav class="flex items-center justify-between mb-12 text-sm">
  <div class="relative">
    <h1
      class="text-3xl font-semibold tracking-tight text-white text-balance animate-fade-in"
    >
      Leonard Paturel
    </h1>

    <p class="text-gray-500 animate-fade-in absolute top-full mt-1">
      software engineer ·
    </p>
  </div>

  <div class="flex space-x-1 sm:space-x-4">
    {
      links.map(({ href, label }) => (
        <div class="group flex flex-col">
          <a
            href={href}
            class:list={[
              baseLinkClass,

              pathname === href ? "text-white" : "text-gray-500",
            ]}
          >
            {label}
          </a>

          <div
            class:list={[
              "bg-neutral-200 h-px mt-1 transition-opacity duration-500",

              pathname === href
                ? "opacity-100"
                : "opacity-0 group-hover:opacity-100",
            ]}
          />
        </div>
      ))
    }
  </div>
</nav>
