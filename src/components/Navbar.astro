---
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "home" },
  { href: "/work", label: "work" },
  { href: "/projects", label: "projects" },
  { href: "/notes", label: "notes" },
];

const baseLinkClass =
  "hover:text-text hover:-translate-y-0.5 transition-transform duration-300 ease-in-out transition-colors duration-200 px-1.5 pb-1 pt-2 sm:px-0 sm:py-0";
---

<nav class="mb-12 flex items-center justify-between text-sm">
  <div class="relative">
    <h1 class="text-4xl font-semibold text-balance">Leonard Paturel</h1>

    <p class="text-text/45 absolute top-full mt-1">software engineer</p>
  </div>

  <div class="flex space-x-1 sm:space-x-4">
    {
      links.map(({ href, label }) => {
        const isActive =
          href === "/" ? pathname === "/" : pathname.startsWith(`${href}`);

        return (
          <div class="group flex flex-col">
            <a
              href={href}
              class:list={[baseLinkClass, isActive ? "" : "text-text/45"]}
            >
              {label}
            </a>

            <div
              class:list={[
                "bg-accent h-px transition-opacity duration-500 sm:mt-1",

                isActive ? "opacity-100" : "opacity-0 group-hover:opacity-100",
              ]}
            />
          </div>
        );
      })
    }
  </div>
</nav>
