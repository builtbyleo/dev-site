---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";

type PortfolioEntry = CollectionEntry<"work"> | CollectionEntry<"projects">;
type EndDate = PortfolioEntry["data"]["endDate"];

interface Props {
  item: PortfolioEntry;
}

const { item } = Astro.props;
const { Content } = await render(item);

const formatMonthYear = (date: Date | EndDate) =>
  date === "present"
    ? "present"
    : date.toLocaleDateString("en-US", {
        month: "short",
        year: "numeric",
      });
---

<a
  id={item.id}
  href={item.data.link}
  target="_blank"
  rel="noopener noreferrer"
  class="corner-draw group -mx-4 mb-3 block scroll-mt-28 px-4 py-3 focus-visible:outline-offset-4"
>
  <div>
    <div class="flex items-center justify-between">
      <div>
        <div class="flex w-full items-center justify-between">
          <h1>
            {item.data.title}
          </h1>
        </div>
      </div>
      <p class="shrink-0 text-sm text-gray-500 tabular-nums">
        {formatMonthYear(item.data.date)}
        <span>-</span>
        {formatMonthYear(item.data.endDate)}
      </p>
    </div>
  </div>
  <div class="flex items-center text-sm text-gray-500">
    {
      item.data.technology.map((item, index) => (
        <>
          {index > 0 && (
            <span class="mx-1 text-xl font-bold text-gray-600">·</span>
          )}
          <span>{item}</span>
        </>
      ))
    }
  </div>
  <div
    class="prose prose-invert prose-p:text-justify prose-p:leading-5 prose-p:font-roboto font-medium"
  >
    <Content />
  </div>
</a>

<style>
  @layer components {
    .corner-draw {
      --corner-size: 1.5rem;
      --corner-thickness: 1px;

      background-image:
        linear-gradient(var(--color-accent), var(--color-accent)),
        linear-gradient(var(--color-accent), var(--color-accent)),
        linear-gradient(var(--color-accent), var(--color-accent)),
        linear-gradient(var(--color-accent), var(--color-accent)),
        linear-gradient(var(--color-accent), var(--color-accent)),
        linear-gradient(var(--color-accent), var(--color-accent)),
        linear-gradient(var(--color-accent), var(--color-accent)),
        linear-gradient(var(--color-accent), var(--color-accent));
      background-position:
        top left,
        top left,
        top right,
        top right,
        bottom left,
        bottom left,
        bottom right,
        bottom right;
      background-repeat: no-repeat;
      background-size:
        0 var(--corner-thickness),
        var(--corner-thickness) 0,
        0 var(--corner-thickness),
        var(--corner-thickness) 0,
        0 var(--corner-thickness),
        var(--corner-thickness) 0,
        0 var(--corner-thickness),
        var(--corner-thickness) 0;
      transition: background-size 700ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .corner-draw:hover,
    .corner-draw:focus-visible,
    .corner-draw:target {
      background-size:
        var(--corner-size) var(--corner-thickness),
        var(--corner-thickness) var(--corner-size),
        var(--corner-size) var(--corner-thickness),
        var(--corner-thickness) var(--corner-size),
        var(--corner-size) var(--corner-thickness),
        var(--corner-thickness) var(--corner-size),
        var(--corner-size) var(--corner-thickness),
        var(--corner-thickness) var(--corner-size);
    }

    @media (prefers-reduced-motion: reduce) {
      .corner-draw {
        transition-duration: 1ms;
      }
    }
  }
</style>
